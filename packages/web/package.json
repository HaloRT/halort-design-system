{
  "name": "@halort/web",
  "version": "0.1.0",
  "description": "HaloRT web UI components — buttons, inputs, domain cards, and marketing patterns.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "clean": "rm -rf dist",
    "lint": "echo 'No lint configured for web'",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@halort/themes": "*",
    "@halort/utils": "*",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.17.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
